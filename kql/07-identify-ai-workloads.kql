// ═══════════════════════════════════════════════════════════════════════════════
// HOW TO IDENTIFY AI WORKLOADS IN YOUR KUBERNETES CLUSTERS
// ═══════════════════════════════════════════════════════════════════════════════
//
// This query helps you discover and inventory AI/ML workloads across your K8s
// clusters by analyzing process telemetry, package usage, and resource patterns.
//
// WHY THIS MATTERS:
// Before you can secure AI workloads, you need to know where they are. Many
// organizations have "shadow AI" — workloads using ML frameworks that security
// teams don't know about.
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │  WHERE TO RUN                                                           │
// │                                                                         │
// │  Methods 1, 3, 4 (CloudProcessEvents):                                 │
// │    → Microsoft Defender XDR > Advanced Hunting                         │
// │                                                                         │
// │  Method 2 + Image Enrichment (CloudAuditEvents):                       │
// │    → Microsoft Defender XDR > Advanced Hunting                         │
// │                                                                         │
// │  Full unified query:                                                    │
// │    → Microsoft Defender XDR > Advanced Hunting                         │
// │      (both tables available natively — no Sentinel required)           │
// └─────────────────────────────────────────────────────────────────────────┘
//
// SCHEMA: Microsoft Defender XDR Advanced Hunting (CloudProcessEvents + CloudAuditEvents)
// TIME WINDOW: Last 7 days (adjust as needed)
// ═══════════════════════════════════════════════════════════════════════════════

let lookback = 7d;  // Analyze past week of activity

// ────────────────────────────────────────────────────────────────────────────
// METHOD 1: Detect AI Frameworks via Process Command Lines
// Run in: Defender XDR Advanced Hunting
// Note: CloudProcessEvents is scoped to K8s (AKS/EKS/GKE) by definition.
//       KubernetesNamespace and KubernetesPodName are native top-level columns.
// ────────────────────────────────────────────────────────────────────────────
let AIProcessSignatures = 
    CloudProcessEvents
    | where Timestamp > ago(lookback)
    | where FileName has_any ("python", "python3", "uvicorn", "gunicorn", "flask", "fastapi")
    | where ProcessCommandLine has_any (
        // ML Frameworks
        "torch", "pytorch", "tensorflow", "keras", "transformers", "sklearn",
        // LLM / Agent Frameworks
        "langchain", "llamaindex", "openai", "anthropic", "langflow", "autogen",
        // Model Serving
        "vllm", "ray", "mlflow", "triton", "seldon",
        // Vector DBs / Embeddings
        "faiss", "chromadb", "pinecone", "weaviate", "sentence-transformers"
    )
    | extend Framework = case(
        ProcessCommandLine has "torch" or ProcessCommandLine has "pytorch", "PyTorch",
        ProcessCommandLine has "tensorflow", "TensorFlow",
        ProcessCommandLine has "transformers", "HuggingFace Transformers",
        ProcessCommandLine has "langchain", "LangChain",
        ProcessCommandLine has "openai", "OpenAI API",
        ProcessCommandLine has "ray", "Ray",
        ProcessCommandLine has "vllm", "vLLM",
        "Other AI Framework"
    )
    | summarize 
        FirstSeen=min(Timestamp),
        LastSeen=max(Timestamp),
        ExecutionCount=count(),
        SampleCommands=make_set(ProcessCommandLine, 3)
        by KubernetesNamespace, KubernetesPodName, Framework
    | extend DetectionMethod = "Process Command Line"
    | project-rename Namespace=KubernetesNamespace, PodName=KubernetesPodName;

// ────────────────────────────────────────────────────────────────────────────
// METHOD 2: Detect GPU-Enabled Pods (Strong AI Indicator)
// Run in: Defender XDR Advanced Hunting
// ────────────────────────────────────────────────────────────────────────────
let GPUPods = 
    CloudAuditEvents
    | where Timestamp > ago(lookback)
    | where DataSource == "Kubernetes Audit"                       // scope to K8s audit events only
    | where ActionType == "Create"                                 // case-sensitive
    | where tostring(RawEventData.objectRef.resource) == "pods"
    | where tostring(RawEventData.requestObject) has_any ("nvidia", "gpu")
    | extend Namespace = tostring(RawEventData.objectRef.namespace)
    | extend PodName   = tostring(RawEventData.objectRef.name)
    | where isnotempty(Namespace) and isnotempty(PodName)
    | summarize FirstSeen=min(Timestamp) by Namespace, PodName
    | extend LastSeen         = FirstSeen                          // pad for union consistency
    | extend SampleCommands   = dynamic([])                        // pad for union consistency
    | extend Framework        = "GPU-Enabled (likely AI/ML)"
    | extend DetectionMethod  = "GPU Resource Request";

// ────────────────────────────────────────────────────────────────────────────
// METHOD 3: Detect Model File Access (.pt, .bin, .safetensors, .onnx)
// Run in: Defender XDR Advanced Hunting
// ────────────────────────────────────────────────────────────────────────────
let ModelFileAccess = 
    CloudProcessEvents
    | where Timestamp > ago(lookback)
    | where ProcessCommandLine has_any (".pt", ".pth", ".bin", ".safetensors", ".onnx", ".h5", ".pb")
    | extend Framework = case(
        ProcessCommandLine has ".pt" or ProcessCommandLine has ".pth", "PyTorch Model",
        ProcessCommandLine has ".safetensors", "Safetensors Model",
        ProcessCommandLine has ".onnx", "ONNX Model",
        ProcessCommandLine has ".h5" or ProcessCommandLine has ".pb", "TensorFlow Model",
        "Model File"
    )
    | summarize 
        FirstSeen=min(Timestamp),
        LastSeen=max(Timestamp),
        SampleCommands=make_set(ProcessCommandLine, 3)
        by KubernetesNamespace, KubernetesPodName, Framework
    | extend DetectionMethod = "Model File Access"
    | project-rename Namespace=KubernetesNamespace, PodName=KubernetesPodName;

// ────────────────────────────────────────────────────────────────────────────
// METHOD 4: Detect Common AI Package Installation (pip, conda)
// Run in: Defender XDR Advanced Hunting
// ────────────────────────────────────────────────────────────────────────────
let PackageInstalls = 
    CloudProcessEvents
    | where Timestamp > ago(lookback)
    | where ProcessCommandLine has "pip install" or ProcessCommandLine has "conda install"
    | where ProcessCommandLine has_any ("torch", "tensorflow", "transformers", "langchain", "openai")
    | extend PackageMatch = extract(@"(torch|tensorflow|transformers|langchain|openai)", 1, ProcessCommandLine)
    | summarize 
        FirstSeen=min(Timestamp),
        LastSeen=max(Timestamp),
        Packages=make_set(PackageMatch, 10),
        SampleCommands=make_set(ProcessCommandLine, 3)
        by KubernetesNamespace, KubernetesPodName
    | extend Framework       = strcat("pip/conda: ", strcat_array(Packages, ", "))
    | extend DetectionMethod = "Package Installation"
    | project-rename Namespace=KubernetesNamespace, PodName=KubernetesPodName;

// ────────────────────────────────────────────────────────────────────────────
// STEP 5: Combine All Detection Methods
// ────────────────────────────────────────────────────────────────────────────
let AllAIWorkloads = 
    AIProcessSignatures
    | union GPUPods
    | union ModelFileAccess
    | union PackageInstalls
    | summarize 
        FirstDetected=min(FirstSeen),
        LastActivity=max(coalesce(LastSeen, FirstSeen)),
        Frameworks=make_set(Framework),
        DetectionMethods=make_set(DetectionMethod),
        SampleCommands=any(SampleCommands)
        by Namespace, PodName;

// ────────────────────────────────────────────────────────────────────────────
// FINAL OUTPUT: Enriched AI Workload Inventory
// ────────────────────────────────────────────────────────────────────────────
AllAIWorkloads
| join kind=leftouter (
    // Enrich with container image info from pod creation events
    CloudAuditEvents
    | where Timestamp > ago(lookback)
    | where DataSource == "Kubernetes Audit"
    | where ActionType == "Create"
    | where tostring(RawEventData.objectRef.resource) == "pods"
    | extend Namespace  = tostring(RawEventData.objectRef.namespace)
    | extend PodName    = tostring(RawEventData.objectRef.name)
    // Capture all container images, not just index [0]
    | extend AllImages  = tostring(RawEventData.requestObject.spec.containers)
    | extend InitImages = tostring(RawEventData.requestObject.spec.initContainers)
    | summarize Image=any(AllImages), InitImage=any(InitImages) by Namespace, PodName
) on Namespace, PodName
| extend RiskScore = case(
    // High risk: GPU + multiple frameworks
    array_length(Frameworks) >= 3 and DetectionMethods has "GPU Resource Request", 8,
    // Medium-high risk: Multiple frameworks or GPU-enabled
    array_length(Frameworks) >= 2 or DetectionMethods has "GPU Resource Request", 6,
    // Medium risk: Single framework, no GPU
    array_length(Frameworks) == 1, 4,
    // Lower risk: Only package install (maybe CI/dev)
    DetectionMethods == pack_array("Package Installation"), 2,
    2  // default
)
| extend Recommendation = case(
    RiskScore >= 7, "HIGH PRIORITY — Review immediately. Likely production AI workload with elevated risk.",
    RiskScore >= 5, "MEDIUM PRIORITY — Validate security posture. Check for over-permissioned identities.",
    RiskScore >= 3, "LOW PRIORITY — Monitor for changes. May be dev/test workload.",
    "INFORMATIONAL — Minimal AI activity detected."
)
| project 
    Namespace,
    PodName,
    RiskScore,
    Recommendation,
    Frameworks,
    DetectionMethods,
    Image,
    InitImage,
    FirstDetected,
    LastActivity,
    DaysActive=datetime_diff('day', LastActivity, FirstDetected),
    SampleCommands
| order by RiskScore desc, LastActivity desc

// ═══════════════════════════════════════════════════════════════════════════════
// HOW TO USE THIS QUERY:
// ═══════════════════════════════════════════════════════════════════════════════
//
// 1. RUN QUERY IN DEFENDER XDR ADVANCED HUNTING
//    - Scope to your AKS clusters
//    - Adjust `lookback` period as needed (default: 7 days)
//
// 2. REVIEW HIGH-RISK WORKLOADS FIRST
//    - RiskScore 7-10: Production AI workloads — prioritize security hardening
//    - RiskScore 4-6: Validate whether these should exist
//    - RiskScore 1-3: Development/test — lower priority
//
// 3. FOR EACH IDENTIFIED WORKLOAD, ASK:
//    ✓ Is this workload supposed to be here?
//    ✓ Does it need GPU access?
//    ✓ What cloud permissions does it have? (ServiceAccount + workload identity)
//    ✓ Is the image signed and from a trusted registry?
//    ✓ Does it load external models? Are they hash-validated?
//
// 4. USE AS BASELINE FOR ONGOING MONITORING
//    - Schedule this query weekly
//    - Alert on new high-risk workloads
//    - Track risk score changes over time
//
// ═══════════════════════════════════════════════════════════════════════════════
// NEXT STEPS AFTER IDENTIFICATION:
// ═══════════════════════════════════════════════════════════════════════════════
//
// Once you've identified AI workloads:
//
// → Run security audit scripts (see /scripts/ directory in this repo)
// → Apply hardening checklist (see /checklists/ directory)
// → Enable hunting queries for anomaly detection (see other .kql files)
// → Review incident response playbook (see /playbooks/ directory)
//
// ═══════════════════════════════════════════════════════════════════════════════
